# ---------------------------------------------------------------------------
# Variáveis de ambiente da Cátedra Política
# Copie este arquivo para `.env.local` e preencha com os valores do seu projeto
# Supabase (veja SUPABASE_SETUP.md, passo 2).
# ---------------------------------------------------------------------------

# URL do projeto Supabase. Pode ir para o navegador (prefixo NEXT_PUBLIC_).
# Ex.: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública "anon". Pode ir para o navegador. Protegida pelas políticas RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave "service_role" — ACESSO TOTAL, ignora o RLS.
# NUNCA exponha no navegador. Sem prefixo NEXT_PUBLIC_. Usada só no servidor
# (Server Actions, scripts) e no painel da Vercel como variável server-only.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública do site (usada em metadados, sitemap, Open Graph).
NEXT_PUBLIC_SITE_URL=https://catedrapolitica.com.br
